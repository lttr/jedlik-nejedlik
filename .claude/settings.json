{
  "permissions": {
    "deny": [
      "Bash(git commit --no-verify:*)",
      "Bash(git commit *--no-verify*)",
      "Bash(git push --no-verify:*)",
      "Bash(git push *--no-verify*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-install.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/post-edit-fix.sh\"",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-smart.sh\"",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "extraKnownMarketplaces": {
    "lttr-claude-marketplace": {
      "source": {
        "source": "github",
        "repo": "lttr/claude-marketplace"
      }
    }
  },
  "enabledPlugins": {
    "aiwork@lttr-claude-marketplace": true
  }
}
